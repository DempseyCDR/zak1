# Copy to .env and adjust. Local Homebrew Postgres uses peer auth (no password).
DATABASE_URL=postgresql://rcd@localhost:5432/zak1_dev
TEST_DATABASE_URL=postgresql://rcd@localhost:5432/zak1_test
LOG_LEVEL=info

# Staff session idle window, hours (feature 015). Optional; defaults to 8.
SESSION_IDLE_TTL_HOURS=8

# Google OAuth (feature 015) — needed to RUN the app, not to run the test suite:
# tests verify locally signed ID tokens and never contact Google (constitution v1.2.0).
# Consent screen: User Type "External" (NOT Internal — Internal would lock out short-term
# volunteers on personal Google accounts), publishing status "Published".
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
